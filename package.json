{
  "name": "mangashelf",
  "version": "2.0.3",
  "description": "Desktop manga browser, downloader, and reader powered by the MangaDex API",
  "main": "electron/main.js",
  "author": "Charmed",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "icon": "node scripts/make-icon.js",
    "dist": "electron-builder --win",
    "dist:publish": "electron-builder --win --publish always"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "cheerio": "^1.2.0",
    "electron-updater": "^6.8.9",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.charmed.mangashelf",
    "productName": "MangaShelf",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "LiterallyLink",
      "repo": "Manga-Shelf",
      "releaseType": "release"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        "portable",
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "MangaShelf-${version}-portable.exe"
    }
  }
}
